{
  "scope": "smoke_control",
  "description": "防排烟规则",
  "rules": [
    {
      "id": "SC-0106",
      "scope": "smoke_control",
      "condition": "防烟楼梯间及其前室",
      "conclusion": "应设置防烟设施",
      "conclusion_type": "required",
      "citation": "GB 50016-2014 第8.5.1-1条",
      "priority": 95,
      "tags": [],
      "design_params": {
        "防烟方式": "优先自然排烟（开窗面积 ≥ 2m²），不满足时设机械加压送风",
        "楼梯间余压": "40~50Pa",
        "前室余压": "25~30Pa",
        "加压送风口": "常闭多叶送风口，火灾时电动开启着火层及上下层"
      }
    },
    {
