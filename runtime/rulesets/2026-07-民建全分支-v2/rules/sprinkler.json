      "conclusion": "地上部分应采用湿式系统",
      "conclusion_type": "required",
      "citation": "GB 55036-2022 第4.0.2-1条",
      "priority": 80,
      "tags": [],
      "design_params": {
        "适用环境": "环境温度 4℃~70℃ 的室内场所",
        "喷头类型": "闭式洒水喷头（68℃标准响应）",
        "报警阀组": "每组控制喷头数 ≤ 800个"
      }
    },
    {
      "id": "SP-0093a",
      "scope": "sprinkler",
      "condition": "歌舞娱乐放映游艺场所（地下/半地下或地上四层及以上）",
