  "rules": [
    {
      "id": "SP-0089",
      "scope": "sprinkler",
      "condition": "一类高层公建及其地下/半地下室（除游泳池/溜冰场）",
      "conclusion": "应设置自动灭火系统（宜自喷）",
      "conclusion_type": "required",
      "citation": "GB 50016-2014 第8.3.3-1条",
      "priority": 90,
      "tags": [
        "一类高层公建",
        "地下室"
      ]
    },
    {
      "id": "SP-0090",
      "scope": "sprinkler",
      "condition": "住宅H>100m",
      "conclusion": "应设置自动喷水灭火系统",
      "conclusion_type": "required",
      "citation": "GB 50016-2014 第8.3.3-4条",
      "priority": 90,
      "tags": []
    },
    {
      "id": "SP-0091",
      "scope": "sprinkler",
