    {
      "id": "SP-0093",
      "scope": "sprinkler",
      "condition": "环境温度<4℃或>70℃ || 全地下车库",
      "conclusion": "地下车库或低温区域应采用干式系统或预作用系统",
      "conclusion_type": "required",
      "citation": "GB 55036-2022 第4.0.2-2条",
      "priority": 80,
      "tags": [],
      "design_params": {
