      "conclusion": "应设置自动和手动触发报警装置",
      "conclusion_type": "required",
      "citation": "GB 55036-2022 第12.0.1条",
      "priority": 95,
      "tags": [],
      "design_params": {
        "系统形式": "集中报警系统（含消防控制室）",
        "探测器类型": "点型光电感烟探测器（办公室/走道/病房）",
        "感烟探测器保护面积": "60 m²（层高≤6m）",
        "手动报警按钮间距": "≤ 30m（走道），每防火分区 ≥ 1个",
        "消防广播扬声器": "≥ 3W，走道间距 ≤ 25m"
